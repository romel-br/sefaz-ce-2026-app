# COPIE ESTE ARQUIVO PARA secrets.toml E PREENCHA OS VALORES
# NUNCA COMMITE secrets.toml NO GIT

# Anthropic Claude API
ANTHROPIC_API_KEY = "sk-ant-..."

# Banco de dados
# Para desenvolvimento local: usar SQLite local
DATABASE_URL = "sqlite:///db/local.db"

# Para produção (Streamlit Cloud + Turso):
# DATABASE_URL = "sqlite+libsql://NOME-do-banco-USUARIO.turso.io?authToken=TOKEN_AQUI"

# Senhas dos usuários (gere o hash com: python -c "import bcrypt; print(bcrypt.hashpw(b'sua_senha', bcrypt.gensalt()).decode())")
[users.ariane]
nome = "Ariane"
senha_hash = "$2b$12$..."
perfil = "estudante"

[users.romel]
nome = "Romel"
senha_hash = "$2b$12$..."
perfil = "admin"
